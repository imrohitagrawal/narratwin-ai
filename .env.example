# Gemini
GEMINI_API_KEY=

# Runtime
APP_ENV=local
LOG_LEVEL=INFO

# Storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=./outputs

# Vector store
VECTOR_STORE=chroma
CHROMA_PATH=./.chroma

# Providers
LLM_PROVIDER=gemini
AVATAR_PROVIDER=mock
TTS_PROVIDER=mock
STT_PROVIDER=mock

# Cost controls
ENABLE_GENERATION_CACHE=true
