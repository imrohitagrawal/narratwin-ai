{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/imrohitagrawal/narratwin-ai/blob/main/docs/governance/GOVERNANCE_PREFLIGHT_V1.schema.json",
  "title": "GovernancePreflightV1",
  "description": "Closed, versioned contract for proving a governance change feasible before implementation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_subject",
    "review_evidence",
    "correction_history"
  ],
  "properties": {
    "review_subject": {
      "$ref": "#/$defs/reviewSubject"
    },
    "review_evidence": {
      "$ref": "#/$defs/reviewEvidence"
    },
    "correction_history": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/correctionRecord"
      },
      "maxItems": 2
    }
  },
  "$defs": {
    "nonBlankString": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "url": {
      "type": "string",
      "pattern": "^https://github\\.com/imrohitagrawal/narratwin-ai/(issues|pull)/[0-9]+(?:#issuecomment-[0-9]+)?$"
    },
    "path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*\\\\)(?!.*[*?\\[])(?!.*//).+$"
    },
    "prefix": {
      "allOf": [
        {
          "$ref": "#/$defs/path"
        },
        {
          "pattern": "/$"
        }
      ]
    },
    "uniqueNonBlankStrings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/nonBlankString"
      }
    },
    "paths": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/path"
      }
    },
    "prefixes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/prefix"
      }
    },
    "linkedIssue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "number",
        "url"
      ],
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "url": {
          "$ref": "#/$defs/url"
        }
      }
    },
    "authorityDomain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "owner"
      ],
      "properties": {
        "domain": {
          "$ref": "#/$defs/identifier"
        },
        "owner": {
          "$ref": "#/$defs/nonBlankString"
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status_decision",
        "required_files",
        "allowed_files",
        "allowed_prefixes",
        "forbidden_files",
        "forbidden_prefixes"
      ],
      "properties": {
        "status_decision": {
          "const": "update-minimally"
        },
        "required_files": {
          "$ref": "#/$defs/paths"
        },
        "allowed_files": {
          "$ref": "#/$defs/paths"
        },
        "allowed_prefixes": {
          "$ref": "#/$defs/prefixes"
        },
        "forbidden_files": {
          "$ref": "#/$defs/paths"
        },
        "forbidden_prefixes": {
          "$ref": "#/$defs/prefixes"
        }
      }
    },
    "invariant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "claim",
        "disproof_mutations",
        "evidence_targets"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^GPF-[A-Z]+(?:-[A-Z]+)*-[0-9]{3}$"
        },
        "claim": {
          "$ref": "#/$defs/nonBlankString"
        },
        "disproof_mutations": {
          "$ref": "#/$defs/uniqueNonBlankStrings"
        },
        "evidence_targets": {
          "$ref": "#/$defs/uniqueNonBlankStrings"
        }
      }
    },
    "localCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "command"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "command": {
          "$ref": "#/$defs/nonBlankString"
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "local_commands",
        "forced_pr_event_command",
        "github_checks"
      ],
      "properties": {
        "profile": {
          "const": "repository-required-v1"
        },
        "local_commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/localCommand"
          }
        },
        "forced_pr_event_command": {
          "$ref": "#/$defs/nonBlankString"
        },
        "github_checks": {
          "$ref": "#/$defs/uniqueNonBlankStrings"
        }
      }
    },
    "bootstrapConstraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase_gate_behavior",
        "admitted_artifact_paths",
        "preserve_runtime_product_rejection",
        "forbid_global_preflight_validation"
      ],
      "properties": {
        "phase_gate_behavior": {
          "const": "admit-only-two-exact-issue169-artifact-paths"
        },
        "admitted_artifact_paths": {
          "$ref": "#/$defs/paths"
        },
        "preserve_runtime_product_rejection": {
          "const": true
        },
        "forbid_global_preflight_validation": {
          "const": true
        }
      }
    },
    "implementationStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "commit_footer",
        "allowed_files"
      ],
      "properties": {
        "id": {
          "enum": [
            "red-tests",
            "guardrail-green",
            "governance-docs"
          ]
        },
        "commit_footer": {
          "$ref": "#/$defs/nonBlankString"
        },
        "allowed_files": {
          "$ref": "#/$defs/paths"
        }
      }
    },
    "implementationCompleteLedger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "carrier",
        "marker",
        "required_fields",
        "decision",
        "timing"
      ],
      "properties": {
        "carrier": {
          "const": "linked-issue-comment"
        },
        "marker": {
          "const": "GOVERNANCE-IMPLEMENTATION-COMPLETE-V1"
        },
        "required_fields": {
          "$ref": "#/$defs/uniqueNonBlankStrings"
        },
        "decision": {
          "const": "READY_FOR_REVIEW"
        },
        "timing": {
          "$ref": "#/$defs/nonBlankString"
        }
      }
    },
    "commitPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "range",
        "bootstrap_branch_pattern",
        "bootstrap_files",
        "implementation_begins_after_bootstrap",
        "cutover",
        "grandfathered_pull_requests_until_rebase",
        "bootstrap_constraints",
        "implementation_steps",
        "implementation_steps_ordered",
        "implementation_steps_single_use",
        "implementation_steps_exhaustive_before_review",
        "commits_after_bootstrap_before_completion",
        "implementation_step_footer_reuse_after_completion",
        "implementation_complete_ledger"
      ],
      "properties": {
        "range": {
          "const": "merge-base(base,head)..head"
        },
        "bootstrap_branch_pattern": {
          "$ref": "#/$defs/nonBlankString"
        },
        "bootstrap_files": {
          "$ref": "#/$defs/paths"
        },
        "implementation_begins_after_bootstrap": {
          "const": true
        },
        "cutover": {
          "const": "bootstrap-or-schema-in-merge-base"
        },
        "grandfathered_pull_requests_until_rebase": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "bootstrap_constraints": {
          "$ref": "#/$defs/bootstrapConstraints"
        },
        "implementation_steps": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "$ref": "#/$defs/implementationStep"
          }
        },
        "implementation_steps_ordered": {
          "const": true
        },
        "implementation_steps_single_use": {
          "const": true
        },
        "implementation_steps_exhaustive_before_review": {
          "const": true
        },
        "commits_after_bootstrap_before_completion": {
          "const": "exactly-one-commit-for-each-ordered-implementation-step"
        },
        "implementation_step_footer_reuse_after_completion": {
          "const": "forbidden"
        },
        "implementation_complete_ledger": {
          "$ref": "#/$defs/implementationCompleteLedger"
        }
      }
    },
    "eventPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "carrier",
        "required_fields",
        "decision"
      ],
      "properties": {
        "carrier": {
          "const": "linked-issue-comment"
        },
        "required_fields": {
          "$ref": "#/$defs/uniqueNonBlankStrings"
        },
        "decision": {
          "$ref": "#/$defs/nonBlankString"
        },
        "must_precede_cycle_implementation_commit": {
          "type": "boolean"
        },
        "must_follow_cycle_implementation_commit": {
          "type": "boolean"
        },
        "approval_comment_url_required": {
          "type": "boolean"
        },
        "approval_reviewer_required": {
          "type": "boolean"
        },
        "approval_reviewed_at_required": {
          "type": "boolean"
        },
        "approval_decision": {
          "type": "string"
        },
        "approval_digest_must_equal_review_subject_sha256": {
          "type": "boolean"
        }
      }
    },
    "rereviewEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "carrier",
        "marker",
        "required_fields",
        "decisions",
        "must_follow_complete_event",
        "reviewed_head_must_equal_correction_head_sha",
        "approved_ends_corrections"
      ],
      "properties": {
        "carrier": {
          "const": "linked-issue-comment"
        },
        "marker": {
          "const": "GOVERNANCE-CORRECTION-REREVIEW-V1"
        },
        "required_fields": {
          "$ref": "#/$defs/uniqueNonBlankStrings"
        },
        "decisions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "APPROVED",
              "NOT_APPROVED"
            ]
          }
        },
        "must_follow_complete_event": {
          "const": true
        },
        "reviewed_head_must_equal_correction_head_sha": {
          "const": true
        },
        "approved_ends_corrections": {
          "const": true
        }
      }
    },
    "cycleTransition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cycle_one_finding_must_postdate_implementation_complete",
        "later_cycle_finding_must_equal_previous_not_approved_rereview_url",
        "later_cycle_finding_must_postdate_previous_complete",
        "later_cycle_forbidden_after_approved_rereview",
        "final_ready_requires_latest_rereview_approved"
      ],
      "properties": {
        "cycle_one_finding_must_postdate_implementation_complete": {
          "const": true
        },
        "later_cycle_finding_must_equal_previous_not_approved_rereview_url": {
          "const": true
        },
        "later_cycle_finding_must_postdate_previous_complete": {
          "const": true
        },
        "later_cycle_forbidden_after_approved_rereview": {
          "const": true
        },
        "final_ready_requires_latest_rereview_approved": {
          "const": true
        }
      }
    },
    "correctionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "design_review_counts_as_cycle",
        "max_post_implementation_cycles",
        "ledger_marker",
        "cycle_reset_commit_footer",
        "cycle_implementation_commit_footer",
        "third_cycle_action",
        "stricter_existing_stop_rules_take_precedence",
        "cycle_numbers_contiguous_from_one",
        "one_reset_commit_per_cycle",
        "one_implementation_commit_per_cycle",
        "footer_use_single_use_per_cycle",
        "planned_step_footer_cannot_classify_correction",
        "finding_url_must_postdate_implementation_complete",
        "resume_event",
        "complete_event",
        "required_order",
        "commits_after_implementation_complete",
        "unledgered_or_extra_post_completion_commit_action",
        "cycle_reset_allowed_files",
        "cycle_reset_forbidden_content",
        "rereview_event",
        "cycle_transition"
      ],
      "properties": {
        "design_review_counts_as_cycle": {
          "const": false
        },
        "max_post_implementation_cycles": {
          "const": 2
        },
        "ledger_marker": {
          "const": "GOVERNANCE-CORRECTION-CYCLE-V1"
        },
        "cycle_reset_commit_footer": {
          "const": "Governance-Correction-Reset: {cycle_number}"
        },
        "cycle_implementation_commit_footer": {
          "const": "Governance-Correction-Cycle: {cycle_number}"
        },
        "third_cycle_action": {
          "const": "STOP_DECOMPOSE"
        },
        "stricter_existing_stop_rules_take_precedence": {
          "const": true
        },
        "cycle_numbers_contiguous_from_one": {
          "const": true
        },
        "one_reset_commit_per_cycle": {
          "const": true
        },
        "one_implementation_commit_per_cycle": {
          "const": true
        },
        "footer_use_single_use_per_cycle": {
          "const": true
        },
        "planned_step_footer_cannot_classify_correction": {
          "const": true
        },
        "finding_url_must_postdate_implementation_complete": {
          "const": true
        },
        "resume_event": {
          "$ref": "#/$defs/eventPolicy"
        },
        "complete_event": {
          "$ref": "#/$defs/eventPolicy"
        },
        "required_order": {
          "$ref": "#/$defs/nonBlankString"
        },
        "commits_after_implementation_complete": {
          "$ref": "#/$defs/nonBlankString"
        },
        "unledgered_or_extra_post_completion_commit_action": {
          "const": "FAIL"
        },
        "cycle_reset_allowed_files": {
          "$ref": "#/$defs/paths"
        },
        "cycle_reset_forbidden_content": {
          "$ref": "#/$defs/nonBlankString"
        },
        "rereview_event": {
          "$ref": "#/$defs/rereviewEvent"
        },
        "cycle_transition": {
          "$ref": "#/$defs/cycleTransition"
        }
      }
    },
    "pathPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "reject_leading_slash",
        "reject_dot_segments",
        "reject_parent_segments",
        "reject_empty_segments",
        "reject_backslashes",
        "reject_globs",
        "prefixes_require_terminal_slash",
        "forbidden_precedence"
      ],
      "properties": {
        "format": {
          "const": "repository-relative-posix"
        },
        "reject_leading_slash": {
          "const": true
        },
        "reject_dot_segments": {
          "const": true
        },
        "reject_parent_segments": {
          "const": true
        },
        "reject_empty_segments": {
          "const": true
        },
        "reject_backslashes": {
          "const": true
        },
        "reject_globs": {
          "const": true
        },
        "prefixes_require_terminal_slash": {
          "const": true
        },
        "forbidden_precedence": {
          "const": true
        }
      }
    },
    "sequencing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_tracker_issue",
        "handoff_comment_url",
        "sole_current_prerequisite_issue",
        "after_issue169_merge_closeout",
        "phf020b_state",
        "parallel_governance_or_runtime_lanes"
      ],
      "properties": {
        "canonical_tracker_issue": {
          "type": "integer",
          "minimum": 1
        },
        "handoff_comment_url": {
          "$ref": "#/$defs/url"
        },
        "sole_current_prerequisite_issue": {
          "type": "integer",
          "minimum": 1
        },
        "after_issue169_merge_closeout": {
          "$ref": "#/$defs/nonBlankString"
        },
        "phf020b_state": {
          "$ref": "#/$defs/nonBlankString"
        },
        "parallel_governance_or_runtime_lanes": {
          "const": "forbidden"
        }
      }
    },
    "reviewSubject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "preflight_id",
        "linked_issue",
        "objective",
        "change_class",
        "authority_domains",
        "scope",
        "invariants",
        "validation",
        "commit_policy",
        "correction_policy",
        "non_goals",
        "path_policy",
        "sequencing"
      ],
      "properties": {
        "schema_version": {
          "const": "GovernancePreflightV1"
        },
        "preflight_id": {
          "type": "string",
          "pattern": "^GPF-[0-9]+-[0-9]{3}$"
        },
        "linked_issue": {
          "$ref": "#/$defs/linkedIssue"
        },
        "objective": {
          "$ref": "#/$defs/nonBlankString"
        },
        "change_class": {
          "enum": [
            "process-guardrail",
            "governance-policy",
            "governance-state",
            "architecture-governance",
            "release-governance"
          ]
        },
        "authority_domains": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/authorityDomain"
          }
        },
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "invariants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/invariant"
          }
        },
        "validation": {
          "$ref": "#/$defs/validation"
        },
        "commit_policy": {
          "$ref": "#/$defs/commitPolicy"
        },
        "correction_policy": {
          "$ref": "#/$defs/correctionPolicy"
        },
        "non_goals": {
          "$ref": "#/$defs/uniqueNonBlankStrings"
        },
        "path_policy": {
          "$ref": "#/$defs/pathPolicy"
        },
        "sequencing": {
          "$ref": "#/$defs/sequencing"
        }
      }
    },
    "reviewEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_subject_sha256",
        "candidate_comment_url",
        "approval_comment_url",
        "reviewer",
        "reviewed_at",
        "decision"
      ],
      "properties": {
        "review_subject_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "candidate_comment_url": {
          "$ref": "#/$defs/url"
        },
        "approval_comment_url": {
          "$ref": "#/$defs/url"
        },
        "reviewer": {
          "$ref": "#/$defs/nonBlankString"
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "decision": {
          "const": "APPROVED"
        }
      }
    },
    "correctionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cycle_number",
        "finding_url",
        "reset_commit",
        "review_subject_sha256",
        "approval_comment_url",
        "correction_commit",
        "complete_comment_url",
        "rereview_comment_url",
        "decision"
      ],
      "properties": {
        "cycle_number": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        },
        "finding_url": {
          "$ref": "#/$defs/url"
        },
        "reset_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "review_subject_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "approval_comment_url": {
          "$ref": "#/$defs/url"
        },
        "correction_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "complete_comment_url": {
          "$ref": "#/$defs/url"
        },
        "rereview_comment_url": {
          "$ref": "#/$defs/url"
        },
        "decision": {
          "enum": [
            "APPROVED",
            "NOT_APPROVED"
          ]
        }
      }
    }
  }
}
