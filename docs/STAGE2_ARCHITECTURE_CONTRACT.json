  "retrievalStrategy": {
    "version": "stage4-rag-v1",
    "topK": 6,
    "minimumScoreThreshold": 0.72,
    "tieBreakOrder": [
      "score desc",
      "approved_at desc",
      "chunk_index asc",
      "chunk_id asc"
    ],
    "fallback": "deterministic keyword overlap fallback only; no cross-project expansion",
    "refusalReasons": [
      "EMPTY_CONTEXT",
      "LOW_RETRIEVAL_CONFIDENCE",
      "AMBIGUOUS_CONTEXT",
      "CROSS_PROJECT_CONTEXT",
      "UNSAFE_CONTEXT"
    ]
  },
